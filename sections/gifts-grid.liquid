{% liquid
  assign bonus_product = section.settings.bonus_product | default: all_products['dark-winter-jacket']
  assign bonus_variant = blank

  if bonus_product != blank
    assign bonus_variant = bonus_product.selected_or_first_available_variant

    for variant in bonus_product.variants
      assign has_bonus_color = false
      assign has_bonus_size = false

      for option_value in variant.options
        assign normalized_option = option_value | strip | downcase

        if normalized_option == 'black'
          assign has_bonus_color = true
        endif

        if normalized_option == 'medium' or normalized_option == 'm'
          assign has_bonus_size = true
        endif
      endfor

      if variant.available and has_bonus_color and has_bonus_size
        assign bonus_variant = variant
        break
      endif
    endfor
  endif
%}

<section
  id="GiftsGrid"
  class="gifts-grid-section"
  data-gifts-grid
  data-bonus-product-handle="{{ bonus_product.handle | escape }}"
  data-bonus-variant-id="{{ bonus_variant.id }}"
  data-currency="{{ cart.currency.iso_code | default: shop.currency }}"
  data-locale="{{ request.locale.iso_code | default: 'en' }}"
>
  <div class="gifts-grid-section__inner">
    {% if section.settings.heading != blank %}
      <h2 class="gifts-grid-section__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    <div class="gifts-grid" role="list">
      {% for block in section.blocks limit: 6 %}
        {% liquid
          assign product = block.settings.product
          assign card_image = block.settings.image
          assign fallback_image_url = ''
          assign fallback_title = ''
          assign fallback_price = ''
          assign fallback_description = ''
          assign fallback_product_handle = ''

          case forloop.index
            when 1
              assign fallback_product_handle = 'black-leather-bag'
              assign fallback_image_url = 'FirstProduct.png' | asset_url
              assign fallback_title = 'Leather shoulder bag'
              assign fallback_price = '120,00&euro;'
              assign fallback_description = 'A polished everyday bag with a structured shape, smooth finish, and enough room for daily essentials.'
            when 2
              assign fallback_product_handle = 'blue-silk-tuxedo'
              assign fallback_image_url = 'secondProduct.png' | asset_url
              assign fallback_title = 'Tailored jacket'
              assign fallback_price = '980,00&euro;'
              assign fallback_description = 'This one-piece swimsuit is crafted from jersey featuring an allover micro Monogram motif in relief.'
            when 3
              assign fallback_product_handle = 'chequered-red-shirt'
              assign fallback_image_url = 'ThirdProduct.png' | asset_url
              assign fallback_title = 'Checked flannel shirt'
              assign fallback_price = '85,00&euro;'
              assign fallback_description = 'A relaxed checked shirt cut from soft brushed cotton for easy layering through the colder months.'
            when 4
              assign fallback_product_handle = 'classic-leather-jacket'
              assign fallback_image_url = 'FourthProduct.png' | asset_url
              assign fallback_title = 'Leather biker jacket'
              assign fallback_price = '560,00&euro;'
              assign fallback_description = 'A clean leather jacket with classic hardware, quilted texture, and a close fit through the shoulders.'
            when 5
              assign fallback_product_handle = 'classic-varsity-top'
              assign fallback_image_url = 'FifthProduct.png' | asset_url
              assign fallback_title = 'Varsity bomber jacket'
              assign fallback_price = '140,00&euro;'
              assign fallback_description = 'A soft bomber jacket with contrast trims and a collegiate patch detail for casual gifting.'
            when 6
              assign fallback_product_handle = 'dark-denim-top'
              assign fallback_image_url = 'SixthProduct.png' | asset_url
              assign fallback_title = 'Denim jacket'
              assign fallback_price = '110,00&euro;'
              assign fallback_description = 'An easy denim layer with a bright, laid-back feel and a versatile cropped silhouette.'
          endcase

          if product == blank and fallback_product_handle != blank
            assign product = all_products[fallback_product_handle]
          endif

          if card_image == blank and product != blank
            assign card_image = product.featured_image
          endif
        %}

        <article
          class="gift-look-card"
          role="listitem"
          style="--gift-hotspot-x: {{ block.settings.hotspot_x }}%; --gift-hotspot-y: {{ block.settings.hotspot_y }}%;"
          {{ block.shopify_attributes }}
        >
          <div class="gift-look-card__media">
            {% if fallback_image_url != blank %}
              <img
                class="gift-look-card__image"
                src="{{ fallback_image_url }}"
                width="1200"
                height="1200"
                loading="lazy"
                alt="{{ fallback_title | escape }}"
              >
            {% elsif card_image != blank %}
              {{
                card_image
                | image_url: width: 1200
                | image_tag:
                  widths: '360, 540, 720, 960, 1200',
                  sizes: '(min-width: 990px) 33vw, (min-width: 480px) 50vw, 100vw',
                  loading: 'lazy',
                  class: 'gift-look-card__image',
                  alt: card_image.alt | default: product.title
              }}
            {% else %}
              <div class="gift-look-card__placeholder">
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                <span>Product image</span>
              </div>
            {% endif %}

            {% if product != blank or fallback_image_url != blank %}
              <button
                type="button"
                class="gift-hotspot"
                aria-label="Open {% if product != blank %}{{ product.title | escape }}{% else %}{{ fallback_title | escape }}{% endif %} details"
                aria-haspopup="dialog"
                aria-controls="GiftPopup-{{ section.id }}-{{ block.id }}"
                data-gift-popup-open="GiftPopup-{{ section.id }}-{{ block.id }}"
              >
                <span aria-hidden="true">+</span>
              </button>
            {% else %}
              <span class="gift-hotspot gift-hotspot--disabled" aria-hidden="true">+</span>
            {% endif %}
          </div>
        </article>

        {% if product != blank or fallback_image_url != blank %}
          {% render 'gift-product-popup',
            product: product,
            card_image: card_image,
            fallback_image_url: fallback_image_url,
            fallback_title: fallback_title,
            fallback_price: fallback_price,
            fallback_description: fallback_description,
            section_id: section.id,
            block_id: block.id
          %}
        {% endif %}
      {% else %}
        {% for index in (1..6) %}
          <article class="gift-look-card" role="listitem">
            <div class="gift-look-card__media">
              <div class="gift-look-card__placeholder">
                {{ 'product-' | append: index | placeholder_svg_tag: 'placeholder-svg' }}
                <span>Select a product in the customizer</span>
              </div>
            </div>
          </article>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

<script src="{{ 'gifts-page.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Gifts product grid",
  "tag": "section",
  "class": "section-gifts-grid",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "header",
      "content": "Automatic bonus product"
    },
    {
      "type": "product",
      "id": "bonus_product",
      "label": "Soft Winter Jacket product",
      "info": "Its first available variant is added automatically when the chosen variant contains both Black and Medium."
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product hotspot",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Grid image",
          "info": "Leave empty to use the product featured image."
        },
        {
          "type": "range",
          "id": "hotspot_x",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Hotspot horizontal position",
          "default": 50
        },
        {
          "type": "range",
          "id": "hotspot_y",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Hotspot vertical position",
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gifts product grid",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
