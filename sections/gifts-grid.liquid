{% liquid
  assign bonus_product = section.settings.bonus_product
  assign bonus_variant = blank

  if bonus_product != blank
    assign bonus_variant = bonus_product.selected_or_first_available_variant
  endif
%}

<section
  id="GiftsGrid"
  class="gifts-grid-section"
  data-gifts-grid
  data-bonus-product-handle="{{ bonus_product.handle | escape }}"
  data-bonus-variant-id="{{ bonus_variant.id }}"
  data-currency="{{ cart.currency.iso_code | default: shop.currency }}"
  data-locale="{{ request.locale.iso_code | default: 'en' }}"
>
  <div class="gifts-grid-section__inner">
    {% if section.settings.heading != blank %}
      <h2 class="gifts-grid-section__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    <div class="gifts-grid" role="list">
      {% for block in section.blocks limit: 6 %}
        {% liquid
          assign product = block.settings.product
          assign card_image = block.settings.image

          if card_image == blank and product != blank
            assign card_image = product.featured_image
          endif
        %}

        <article
          class="gift-look-card"
          role="listitem"
          style="--gift-hotspot-x: {{ block.settings.hotspot_x }}%; --gift-hotspot-y: {{ block.settings.hotspot_y }}%;"
          {{ block.shopify_attributes }}
        >
          <div class="gift-look-card__media">
            {% if card_image != blank %}
              {{
                card_image
                | image_url: width: 1200
                | image_tag:
                  widths: '360, 540, 720, 960, 1200',
                  sizes: '(min-width: 990px) 33vw, (min-width: 480px) 50vw, 100vw',
                  loading: 'lazy',
                  class: 'gift-look-card__image',
                  alt: card_image.alt | default: product.title
              }}
            {% else %}
              <div class="gift-look-card__placeholder">
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                <span>Product image</span>
              </div>
            {% endif %}

            {% if product != blank %}
              <button
                type="button"
                class="gift-hotspot"
                aria-label="Open {{ product.title | escape }} details"
                aria-haspopup="dialog"
                aria-controls="GiftPopup-{{ section.id }}-{{ block.id }}"
                data-gift-popup-open="GiftPopup-{{ section.id }}-{{ block.id }}"
              >
                <span aria-hidden="true">+</span>
              </button>
            {% else %}
              <span class="gift-hotspot gift-hotspot--disabled" aria-hidden="true">+</span>
            {% endif %}
          </div>
        </article>

        {% if product != blank %}
          {% render 'gift-product-popup',
            product: product,
            card_image: card_image,
            section_id: section.id,
            block_id: block.id
          %}
        {% endif %}
      {% else %}
        {% for index in (1..6) %}
          <article class="gift-look-card" role="listitem">
            <div class="gift-look-card__media">
              <div class="gift-look-card__placeholder">
                {{ 'product-' | append: index | placeholder_svg_tag: 'placeholder-svg' }}
                <span>Select a product in the customizer</span>
              </div>
            </div>
          </article>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

<script src="{{ 'gifts-page.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Gifts product grid",
  "tag": "section",
  "class": "section-gifts-grid",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "header",
      "content": "Automatic bonus product"
    },
    {
      "type": "product",
      "id": "bonus_product",
      "label": "Soft Winter Jacket product",
      "info": "Its first available variant is added automatically when the chosen variant contains both Black and Medium."
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product hotspot",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Grid image",
          "info": "Leave empty to use the product featured image."
        },
        {
          "type": "range",
          "id": "hotspot_x",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Hotspot horizontal position",
          "default": 50
        },
        {
          "type": "range",
          "id": "hotspot_y",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Hotspot vertical position",
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gifts product grid",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
